{
  "kind": "Dashboard",
  "metadata": {
    "name": "memory-aware-rebalancing",
    "project": "descheduler",
    "createdAt": "0001-01-01T00:00:00Z",
    "updatedAt": "0001-01-01T00:00:00Z",
    "version": 0
  },
  "spec": {
    "duration": "1h",
    "refreshInterval": "1m",
    "variables": [
      {
        "kind": "ListVariable",
        "spec": {
          "name": "node",
          "display": {
            "name": "Node",
            "hidden": false
          },
          "allowMultiple": true,
          "allowAllValue": true,
          "plugin": {
            "kind": "PrometheusLabelValuesVariable",
            "spec": {
              "labelName": "instance",
              "matchers": [
                "descheduler:nodeutilization:cpu:avg1m"
              ]
            }
          }
        }
      },
      {
        "kind": "ListVariable",
        "spec": {
          "name": "limit",
          "display": {
            "name": "Max evictions shown",
            "hidden": false
          },
          "allowMultiple": false,
          "allowAllValue": false,
          "defaultValue": "15",
          "plugin": {
            "kind": "StaticListVariable",
            "spec": {
              "values": [
                "10",
                "15",
                "20"
              ]
            }
          }
        }
      }
    ],
    "panels": {
      "cpuUtilByNode": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "CPU Utilization \u2014 per Node",
            "description": "CPU utilization over time for each node. The red \u2605 avg workers series is the fleet average \u2014 nodes far from it are candidates for rebalancing."
          },
          "plugin": {
            "kind": "TimeSeriesChart",
            "spec": {
              "legend": {
                "position": "right",
                "mode": "list"
              },
              "yAxis": {
                "label": "CPU Utilization",
                "format": {
                  "unit": "percent-decimal"
                },
                "min": 0
              },
              "visual": {
                "display": "line",
                "lineWidth": 1,
                "areaOpacity": 0.05
              },
              "querySettings": [
                {
                  "queryIndex": 1,
                  "colorMode": "fixed-single",
                  "colorValue": "#e02020"
                }
              ]
            }
          },
          "queries": [
            {
              "kind": "TimeSeriesQuery",
              "spec": {
                "plugin": {
                  "kind": "PrometheusTimeSeriesQuery",
                  "spec": {
                    "query": "descheduler:nodeutilization:cpu:avg1m{instance=~\"$node\"}",
                    "seriesNameFormat": "{{instance}}"
                  }
                }
              }
            },
            {
              "kind": "TimeSeriesQuery",
              "spec": {
                "plugin": {
                  "kind": "PrometheusTimeSeriesQuery",
                  "spec": {
                    "query": "descheduler:averageworkersutilization:cpu:avg1m{}",
                    "seriesNameFormat": "\u2605 avg workers"
                  }
                }
              }
            }
          ]
        }
      },
      "memUtilByNode": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Memory Utilization \u2014 per Node",
            "description": "Memory utilization over time for each node. The red \u2605 avg workers series is the fleet average \u2014 nodes far from it are candidates for rebalancing."
          },
          "plugin": {
            "kind": "TimeSeriesChart",
            "spec": {
              "legend": {
                "position": "right",
                "mode": "list"
              },
              "yAxis": {
                "label": "Memory Utilization",
                "format": {
                  "unit": "percent-decimal"
                },
                "min": 0
              },
              "visual": {
                "display": "line",
                "lineWidth": 1,
                "areaOpacity": 0.05
              },
              "querySettings": [
                {
                  "queryIndex": 1,
                  "colorMode": "fixed-single",
                  "colorValue": "#e02020"
                }
              ]
            }
          },
          "queries": [
            {
              "kind": "TimeSeriesQuery",
              "spec": {
                "plugin": {
                  "kind": "PrometheusTimeSeriesQuery",
                  "spec": {
                    "query": "descheduler:nodeutilization:memory:avg1m{instance=~\"$node\"}",
                    "seriesNameFormat": "{{instance}}"
                  }
                }
              }
            },
            {
              "kind": "TimeSeriesQuery",
              "spec": {
                "plugin": {
                  "kind": "PrometheusTimeSeriesQuery",
                  "spec": {
                    "query": "descheduler:averageworkersutilization:memory:avg1m{}",
                    "seriesNameFormat": "\u2605 avg workers"
                  }
                }
              }
            }
          ]
        }
      },
      "cpuPressureByNode": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "CPU Pressure (PSI) \u2014 per Node",
            "description": "CPU PSI pressure over time per node. Near-zero under normal conditions. The red \u2605 avg workers is the fleet average."
          },
          "plugin": {
            "kind": "TimeSeriesChart",
            "spec": {
              "legend": {
                "position": "right",
                "mode": "list"
              },
              "yAxis": {
                "label": "CPU Pressure",
                "format": {
                  "unit": "percent-decimal"
                },
                "min": 0
              },
              "visual": {
                "display": "line",
                "lineWidth": 1,
                "areaOpacity": 0.05
              },
              "querySettings": [
                {
                  "queryIndex": 1,
                  "colorMode": "fixed-single",
                  "colorValue": "#e02020"
                }
              ]
            }
          },
          "queries": [
            {
              "kind": "TimeSeriesQuery",
              "spec": {
                "plugin": {
                  "kind": "PrometheusTimeSeriesQuery",
                  "spec": {
                    "query": "descheduler:nodepressure:cpu:avg1m{instance=~\"$node\"}",
                    "seriesNameFormat": "{{instance}}"
                  }
                }
              }
            },
            {
              "kind": "TimeSeriesQuery",
              "spec": {
                "plugin": {
                  "kind": "PrometheusTimeSeriesQuery",
                  "spec": {
                    "query": "descheduler:averageworkerspressure:cpu:avg1m{}",
                    "seriesNameFormat": "\u2605 avg workers"
                  }
                }
              }
            }
          ]
        }
      },
      "memPressureByNode": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Memory Pressure (PSI) \u2014 per Node",
            "description": "Memory PSI pressure over time per node. Near-zero under normal conditions. The red \u2605 avg workers is the fleet average."
          },
          "plugin": {
            "kind": "TimeSeriesChart",
            "spec": {
              "legend": {
                "position": "right",
                "mode": "list"
              },
              "yAxis": {
                "label": "Memory Pressure",
                "format": {
                  "unit": "percent-decimal"
                },
                "min": 0
              },
              "visual": {
                "display": "line",
                "lineWidth": 1,
                "areaOpacity": 0.05
              },
              "querySettings": [
                {
                  "queryIndex": 1,
                  "colorMode": "fixed-single",
                  "colorValue": "#e02020"
                }
              ]
            }
          },
          "queries": [
            {
              "kind": "TimeSeriesQuery",
              "spec": {
                "plugin": {
                  "kind": "PrometheusTimeSeriesQuery",
                  "spec": {
                    "query": "descheduler:nodepressure:memory:avg1m{instance=~\"$node\"}",
                    "seriesNameFormat": "{{instance}}"
                  }
                }
              }
            },
            {
              "kind": "TimeSeriesQuery",
              "spec": {
                "plugin": {
                  "kind": "PrometheusTimeSeriesQuery",
                  "spec": {
                    "query": "descheduler:averageworkerspressure:memory:avg1m{}",
                    "seriesNameFormat": "\u2605 avg workers"
                  }
                }
              }
            }
          ]
        }
      },
      "utilizationValues": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Synthetic Node Utilization Value vs Dynamic Thresholds",
            "description": "The descheduler's computed synthetic utilization score per node (combining CPU and memory). Nodes above the high threshold (red dashed) are Overutilized; nodes below the low threshold (orange dashed) are Underutilized and will receive migrated workloads."
          },
          "plugin": {
            "kind": "TimeSeriesChart",
            "spec": {
              "legend": {
                "position": "right",
                "mode": "table",
                "values": [
                  "last"
                ]
              },
              "yAxis": {
                "label": "Utilization Value",
                "format": {
                  "unit": "percent-decimal"
                },
                "min": 0
              },
              "visual": {
                "display": "line",
                "lineWidth": 1,
                "areaOpacity": 0.05
              },
              "querySettings": [
                {
                  "queryIndex": 1,
                  "colorMode": "fixed-single",
                  "colorValue": "#f2495c"
                },
                {
                  "queryIndex": 2,
                  "colorMode": "fixed-single",
                  "colorValue": "#ff9830"
                }
              ]
            }
          },
          "queries": [
            {
              "kind": "TimeSeriesQuery",
              "spec": {
                "plugin": {
                  "kind": "PrometheusTimeSeriesQuery",
                  "spec": {
                    "query": "descheduler_lownodeutilization_node_utilization_value{node=~\"$node\"}",
                    "seriesNameFormat": "{{node}}"
                  }
                }
              }
            },
            {
              "kind": "TimeSeriesQuery",
              "spec": {
                "plugin": {
                  "kind": "PrometheusTimeSeriesQuery",
                  "spec": {
                    "query": "avg(descheduler_lownodeutilization_node_utilization_threshold{threshold_type=\"high\"})",
                    "seriesNameFormat": "High Threshold"
                  }
                }
              }
            },
            {
              "kind": "TimeSeriesQuery",
              "spec": {
                "plugin": {
                  "kind": "PrometheusTimeSeriesQuery",
                  "spec": {
                    "query": "avg(descheduler_lownodeutilization_node_utilization_threshold{threshold_type=\"low\"})",
                    "seriesNameFormat": "Low Threshold"
                  }
                }
              }
            }
          ]
        }
      },
      "nodeClassification": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Node Classification over Time",
            "description": "Each row is a node. The color shows how the descheduler classified it at each point in time: Underutilized (blue, will receive workloads), Normal (green, balanced), Overutilized (red, workloads will be evicted/migrated away)."
          },
          "plugin": {
            "kind": "StatusHistoryChart",
            "spec": {
              "legend": {
                "position": "bottom"
              },
              "mappings": [
                {
                  "kind": "Value",
                  "spec": {
                    "value": "0",
                    "result": {
                      "value": "Underutilized",
                      "color": "#5794f2"
                    }
                  }
                },
                {
                  "kind": "Value",
                  "spec": {
                    "value": "1",
                    "result": {
                      "value": "Normal",
                      "color": "#73bf69"
                    }
                  }
                },
                {
                  "kind": "Value",
                  "spec": {
                    "value": "2",
                    "result": {
                      "value": "Overutilized",
                      "color": "#f2495c"
                    }
                  }
                }
              ]
            }
          },
          "queries": [
            {
              "kind": "TimeSeriesQuery",
              "spec": {
                "plugin": {
                  "kind": "PrometheusTimeSeriesQuery",
                  "spec": {
                    "query": "descheduler_lownodeutilization_node_classification{node=~\"$node\"}",
                    "seriesNameFormat": "{{node}}"
                  }
                }
              }
            }
          ]
        }
      },
      "totalEvictions": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Total Evictions",
            "description": "Cumulative pods evicted by the KubeVirtRelieveAndMigrate profile across selected nodes."
          },
          "plugin": {
            "kind": "StatChart",
            "spec": {
              "calculation": "last-number",
              "format": {
                "unit": "decimal",
                "decimalPlaces": 0
              }
            }
          },
          "queries": [
            {
              "kind": "TimeSeriesQuery",
              "spec": {
                "plugin": {
                  "kind": "PrometheusTimeSeriesQuery",
                  "spec": {
                    "query": "sum(descheduler_pods_evicted{profile=\"KubeVirtRelieveAndMigrate\", result=\"success\", node=~\"$node\"})",
                    "seriesNameFormat": "Evictions"
                  }
                }
              }
            }
          ]
        }
      },
      "evictionsRate": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Evictions (KubeVirtRelieveAndMigrate) \u2014 per Node, rolling 5 min",
            "description": "Number of successful evictions in the trailing 5-minute window per node. A single eviction event appears as 1 for ~5 minutes then drops back to 0."
          },
          "plugin": {
            "kind": "TimeSeriesChart",
            "spec": {
              "legend": {
                "position": "right",
                "mode": "table",
                "values": [
                  "last"
                ]
              },
              "yAxis": {
                "label": "Evictions (last 5 min)",
                "format": {
                  "unit": "decimal",
                  "decimalPlaces": 0
                },
                "min": 0
              },
              "visual": {
                "display": "line",
                "lineWidth": 2,
                "areaOpacity": 0.4
              }
            }
          },
          "queries": [
            {
              "kind": "TimeSeriesQuery",
              "spec": {
                "plugin": {
                  "kind": "PrometheusTimeSeriesQuery",
                  "spec": {
                    "query": "clamp_min(delta(descheduler_pods_evicted{profile=\"KubeVirtRelieveAndMigrate\", result=\"success\", node=~\"$node\"}[5m]), 0)",
                    "seriesNameFormat": "{{node}}"
                  }
                }
              }
            }
          ]
        }
      },
      "evictionHistory": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Recent Evictions \u2014 by Node & Namespace",
            "description": "$limit (node, namespace) pairs with the most recent eviction in the trailing 6 hours, sorted by recency (smallest = most recent). \"Last eviction\" shows how long ago the last eviction was detected, measured from now. Lookback is fixed at 6 h from the end of the selected time window."
          },
          "plugin": {
            "kind": "Table",
            "spec": {
              "density": "compact",
              "columnSettings": [
                {
                  "name": "node",
                  "header": "Node",
                  "enableSorting": true
                },
                {
                  "name": "exported_namespace",
                  "header": "Namespace",
                  "enableSorting": true
                },
                {
                  "name": "value",
                  "header": "Last eviction",
                  "enableSorting": true,
                  "sort": "asc",
                  "align": "right",
                  "format": {
                    "unit": "seconds"
                  }
                },
                {
                  "name": "timestamp",
                  "hide": true
                },
                {
                  "name": "endpoint",
                  "hide": true
                },
                {
                  "name": "instance",
                  "hide": true
                },
                {
                  "name": "job",
                  "hide": true
                },
                {
                  "name": "managed_cluster",
                  "hide": true
                },
                {
                  "name": "namespace",
                  "hide": true
                },
                {
                  "name": "pod",
                  "hide": true
                },
                {
                  "name": "pod_namespace",
                  "hide": true
                },
                {
                  "name": "profile",
                  "hide": true
                },
                {
                  "name": "prometheus",
                  "hide": true
                },
                {
                  "name": "result",
                  "hide": true
                },
                {
                  "name": "service",
                  "hide": true
                },
                {
                  "name": "strategy",
                  "hide": true
                }
              ]
            }
          },
          "queries": [
            {
              "kind": "TimeSeriesQuery",
              "spec": {
                "plugin": {
                  "kind": "PrometheusTimeSeriesQuery",
                  "spec": {
                    "query": "bottomk($limit, time() - (max_over_time((time() * (delta(descheduler_pods_evicted{profile=\"KubeVirtRelieveAndMigrate\", result=\"success\", node=~\"$node\"}[5m]) >= bool 1))[6h:1m]) > 0))"
                  }
                }
              }
            }
          ]
        }
      },
      "evictionsTimeSeries": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Pods Evicted (KubeVirtRelieveAndMigrate) \u2014 per Node",
            "description": "Cumulative successful evictions over time broken down by source node."
          },
          "plugin": {
            "kind": "TimeSeriesChart",
            "spec": {
              "legend": {
                "position": "right",
                "mode": "table",
                "values": [
                  "last"
                ]
              },
              "yAxis": {
                "label": "Evicted Pods",
                "format": {
                  "unit": "decimal",
                  "decimalPlaces": 0
                },
                "min": 0
              },
              "visual": {
                "display": "line",
                "lineWidth": 2,
                "areaOpacity": 0.1
              }
            }
          },
          "queries": [
            {
              "kind": "TimeSeriesQuery",
              "spec": {
                "plugin": {
                  "kind": "PrometheusTimeSeriesQuery",
                  "spec": {
                    "query": "descheduler_pods_evicted{profile=\"KubeVirtRelieveAndMigrate\", result=\"success\", node=~\"$node\"}",
                    "seriesNameFormat": "{{node}}"
                  }
                }
              }
            }
          ]
        }
      }
    },
    "layouts": [
      {
        "kind": "Grid",
        "spec": {
          "display": {
            "title": "Utilization \u2014 CPU & Memory per Node",
            "collapse": {
              "open": true
            }
          },
          "items": [
            {
              "x": 0,
              "y": 0,
              "width": 12,
              "height": 10,
              "content": {
                "$ref": "#/spec/panels/cpuUtilByNode"
              }
            },
            {
              "x": 12,
              "y": 0,
              "width": 12,
              "height": 10,
              "content": {
                "$ref": "#/spec/panels/memUtilByNode"
              }
            }
          ]
        }
      },
      {
        "kind": "Grid",
        "spec": {
          "display": {
            "title": "Pressure (PSI) \u2014 CPU & Memory per Node",
            "collapse": {
              "open": true
            }
          },
          "items": [
            {
              "x": 0,
              "y": 0,
              "width": 12,
              "height": 10,
              "content": {
                "$ref": "#/spec/panels/cpuPressureByNode"
              }
            },
            {
              "x": 12,
              "y": 0,
              "width": 12,
              "height": 10,
              "content": {
                "$ref": "#/spec/panels/memPressureByNode"
              }
            }
          ]
        }
      },
      {
        "kind": "Grid",
        "spec": {
          "display": {
            "title": "Synthetic Utilization Value & Dynamic Thresholds",
            "collapse": {
              "open": true
            }
          },
          "items": [
            {
              "x": 0,
              "y": 0,
              "width": 24,
              "height": 10,
              "content": {
                "$ref": "#/spec/panels/utilizationValues"
              }
            }
          ]
        }
      },
      {
        "kind": "Grid",
        "spec": {
          "display": {
            "title": "Node Classification over Time",
            "collapse": {
              "open": true
            }
          },
          "items": [
            {
              "x": 0,
              "y": 0,
              "width": 24,
              "height": 10,
              "content": {
                "$ref": "#/spec/panels/nodeClassification"
              }
            }
          ]
        }
      },
      {
        "kind": "Grid",
        "spec": {
          "display": {
            "title": "Evictions",
            "collapse": {
              "open": true
            }
          },
          "items": [
            {
              "x": 0,
              "y": 0,
              "width": 4,
              "height": 4,
              "content": {
                "$ref": "#/spec/panels/totalEvictions"
              }
            },
            {
              "x": 4,
              "y": 0,
              "width": 20,
              "height": 8,
              "content": {
                "$ref": "#/spec/panels/evictionsTimeSeries"
              }
            },
            {
              "x": 0,
              "y": 8,
              "width": 24,
              "height": 8,
              "content": {
                "$ref": "#/spec/panels/evictionsRate"
              }
            },
            {
              "x": 0,
              "y": 16,
              "width": 24,
              "height": 10,
              "content": {
                "$ref": "#/spec/panels/evictionHistory"
              }
            }
          ]
        }
      }
    ]
  }
}
