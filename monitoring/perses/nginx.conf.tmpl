server {
    listen 9090;

    # Simple health endpoint so the compose healthcheck doesn't hit the upstream
    location /nginx-health {
        access_log off;
        return 200 "ok\n";
        add_header Content-Type text/plain;
    }

    location / {
        proxy_pass https://THANOS_HOST_PLACEHOLDER;

        proxy_ssl_verify          off;
        proxy_ssl_server_name     on;

        proxy_set_header Host     THANOS_HOST_PLACEHOLDER;
        proxy_set_header Authorization "Bearer BEARER_TOKEN_PLACEHOLDER";

        # Strip any client-supplied Authorization to avoid conflicts
        proxy_hide_header Authorization;

        proxy_read_timeout        60s;
        proxy_connect_timeout     10s;
    }
}